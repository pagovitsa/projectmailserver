# Copy this file to .env and adjust values for each server.
MAILSERVER_HOSTNAME=mail.example.com
MAILSERVER_ZONE=example.com
PRIMARY_DOMAIN=example.com
POSTMASTER_ADDRESS=postmaster@example.com
TZ=UTC
WEBMAIL_HOSTNAME=webmail.example.com
ROUNDCUBE_HTTP_PORT=8080

# Prefer an external address here so you still receive renewal notices
# even if the mail server is temporarily down.
CERTBOT_EMAIL=ops@example.com
CERTBOT_CERT_NAME=mail.example.com
CERTBOT_EXTRA_DOMAINS=webmail.example.com
CERTBOT_KEY_TYPE=ecdsa
# Production by default. Set to 1 only if you explicitly want Let's Encrypt staging.
CERTBOT_STAGING=0
CLOUDFLARE_DNS_PROPAGATION_SECONDS=60

# init.sh writes the detected public IPs here for each host.
# If you edit manually, prefer explicit public IPs. Use auto only as a fallback.
MAILSERVER_IPV4=
MAILSERVER_IPV6=

MAIL_MX_PRIORITY=10
MAIL_HELO_SPF_VALUE=v=spf1 a -all
MAIL_SPF_VALUE=v=spf1 mx -all
MAIL_DMARC_VALUE=v=DMARC1;p=quarantine;adkim=s;aspf=s;pct=100
